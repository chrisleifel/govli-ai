{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@govli/shared/*": ["modules/foia/shared/src/*"],
      "@govli/ui/*": ["modules/foia/govli-ui/src/*"]
    }
  },
  "include": ["modules/**/*.ts", "modules/**/*.tsx"],
  "exclude": ["node_modules", "dist", ".next"]
}
