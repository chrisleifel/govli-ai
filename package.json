{
  "name": "govli-ai-v2",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "modules/foia/shared",
    "modules/foia/gateway",
    "modules/foia/ai-sidecar",
    "modules/foia/services/*",
    "modules/foia/ai-features/*",
    "modules/foia/portal",
    "modules/foia/admin",
    "modules/foia/govli-ui",
    "modules/foia/workers",
    "modules/foia/migration/*"
  ],
  "scripts": {
    "foia:dev": "docker-compose up -d && echo FOIA services ready",
    "foia:verify": "tsc --noEmit -p modules/foia/tsconfig.json",
    "foia:test": "jest --config modules/foia/jest.config.ts",
    "foia:lint": "eslint modules/foia/ --ext .ts,.tsx",
    "foia:migrate": "node-pg-migrate -m modules/foia/migrations",
    "foia:build:portal": "cd modules/foia/portal && npm run build",
    "foia:build:admin": "cd modules/foia/admin && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "prettier": "^3.1.0",
    "node-pg-migrate": "^7.0.0"
  }
}
