# === Database ===
DATABASE_URL=postgresql://govli:govli_dev_2026@localhost:5432/govli_foia
DATABASE_POOL_SIZE=20

# === Redis ===
REDIS_URL=redis://localhost:6379

# === S3 / MinIO ===
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=govli-foia-documents
S3_ACCESS_KEY=govli_minio
S3_SECRET_KEY=govli_minio_2026
S3_REGION=us-east-1

# === Anthropic API ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === JWT Auth ===
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# === Encryption ===
AUDIT_ENCRYPTION_KEY=your-256-bit-key-change-in-production
CJIS_ENCRYPTION_KEY=separate-256-bit-key-for-cjis

# === Email ===
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-key
EMAIL_FROM=noreply@govli.ai

# === Application ===
NODE_ENV=development
PORT=3000
PORTAL_PORT=3001
ADMIN_PORT=3002
LOG_LEVEL=debug

# === AI Budget Defaults ===
AI_DEFAULT_MONTHLY_BUDGET_USD=0
AI_MODEL_LOW=haiku-4.5
AI_MODEL_MID=sonnet-4.5
AI_MODEL_HIGH=opus-4.6
AI_PROMPT_CACHE_TTL_SEC=3600
AI_BATCH_ENABLED=true
